# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption (for API keys stored in DB)
ENCRYPTION_KEY=generate-a-32-byte-hex-key

# Vercel Cron (secret for authenticating cron job requests)
CRON_SECRET=generate-a-random-secret-string

# Paddle (billing)
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=pri_...
NEXT_PUBLIC_PADDLE_TEAM_PRICE_ID=pri_...

# Upstash Redis (distributed rate limiting — optional for local dev)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Resend (Email)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E2E Testing
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_PASSWORD=your-test-password
