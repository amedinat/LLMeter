{
  "name": "@simplifai/payments",
  "version": "0.1.0",
  "private": true,
  "description": "Shared payment provider abstraction for Simplifai products",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@paddle/paddle-node-sdk": ">=1.0.0",
    "@paddle/paddle-js": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@paddle/paddle-node-sdk": {
      "optional": true
    },
    "@paddle/paddle-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@paddle/paddle-node-sdk": "^1.8.0",
    "@paddle/paddle-js": "^1.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
